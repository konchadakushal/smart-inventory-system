# =========================================================================
# SMART INVENTORY SYSTEM - ENVIRONMENT TEMPLATE
# Copy this file to './server/.env' and fill in your local settings.
# =========================================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=smart_inventory

# JWT (JSON Web Token) Authentication Configuration
# Provide a secure, long, random secret key for token signing
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=24h
